#############################
# Mailcow / Database / Redis
#############################

# Hostname for your mail server (fully qualified)
MAILCOW_HOSTNAME=mail.ztechai.us

# Timezone
TZ=UTC

# Database credentials
DBNAME=mailcow
DBUSER=mailcow
DBPASS=StrongMailcowDbPass123
DBROOT=StrongRootDbPass456

# Redis password
REDISPASS=StrongRedisPass789

# Additional SANs (Subject Alternative Names) for SSL
# If you use autodiscover or autoconfig subdomains, include them here, comma-separated.
ADDITIONAL_SAN=autodiscover.ztechai.us,autoconfig.ztechai.us

# (Optional) mailcow internal API settings
API_KEY=ReplaceWithYourAPIKey
API_ALLOW_FROM=0.0.0.0/0

# Organization / contact
ORGANIZATION_NAME=ZtechAI
POSTMASTER_ADDRESS=postmaster@ztechai.us
